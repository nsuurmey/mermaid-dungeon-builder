# Copy to .env for local development. Railway provides these via its dashboard.

# Port the server listens on. Railway sets this automatically in production.
PORT=3001

# Where the SQLite DB lives. Defaults to /data (Railway persistent volume).
# For local dev, point it at a folder inside the repo (gitignored).
DATA_DIR=./.data

# Shared password gate. When set, the app requires this password to log in.
# LEAVE EMPTY to disable the gate for local dev. MUST be set in production.
APP_PASSWORD=

# Optional dedicated secret for signing session cookies. Recommended in prod.
# If unset, a secret is derived from APP_PASSWORD.
AUTH_SECRET=
